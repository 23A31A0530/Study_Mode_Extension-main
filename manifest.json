{
  "manifest_version": 3,
  "name": "YouTube Study Mode",
  "version": "1.0.0",
  "description": "Focus on studying by hiding distractions on YouTube. Three modes: Study, Playlist, and Combined.",
  "permissions": ["storage", "activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
